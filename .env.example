# ==== API credentials (see README.md for how to get them) ====
# Rakuten Web Service applicationId (17-19 digit number)
RAKUTEN_APP_ID=

# Yahoo Shopping application (Client) ID
YAHOO_APP_ID=

# Amazon Product Advertising API v5 (needs Associate approval)
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=

# ==== App settings ====
# API key for external system integration. If set, /api/* requires X-API-KEY header.
APP_API_KEY=

# Domain registered in Rakuten "allowed websites" (sent as Referer)
APP_PUBLIC_URL=http://enzantrades.co.jp

# Listening port
PORT=5057

# ==== Open Food Facts (無料・キー不要) ====
# 1=有効 0=無効
OFF_ENABLED=1
# OFFはUser-Agentに連絡先を入れるのが推奨
OFF_CONTACT=your-email@example.com
